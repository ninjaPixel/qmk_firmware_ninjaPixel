# Enable rotary encoder map (per-layer encoder bindings)
ENCODER_MAP_ENABLE = yes

# Enable tap dance (used for TD_NOODLE on the far-left key of row 1)
TAP_DANCE_ENABLE = yes

# Enable caps word (CW_TOGG on layer 2)
CAPS_WORD_ENABLE = yes

# Override bootloader for Elite-C v4 (uses Atmel DFU, not Caterina like Pro Micro)
BOOTLOADER = atmel-dfu
